    "@tanstack/react-start": "^1.95.0",
    "@types/node": "^22.10.7",
    "@vitejs/plugin-react": "^4.3.4",
    "convex": "^1.19.4",
    "effect": "^3.12.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.49.1",
    "@types/react": "^19.0.7",
