RUSTFS_ACCESS_KEY=typst-selfhost
RUSTFS_SECRET_KEY=typst-selfhost-secret

WORKER_ID=worker-1
WORKER_POLL_INTERVAL_MS=2000
WORKER_RENDER_TIMEOUT_MS=30000
